# 虚拟环境（PEP 668 下请用 venv 安装依赖）
.venv/
venv/

# 本地密钥与环境变量，禁止入库
.env
.env.*
!.env.example

# 本机放置供 recon/apk_decompile.py 使用，体积大勿提交（GitHub 单文件约 100MB 上限）
*.apk
doubao_original.apk

# macOS
.DS_Store
__pycache__/
*.py[cod]
.Python
*.log
logs/
# flow_recorder 录制产物（XML/截图/jsonl），体积大且含本机操作痕迹
recon/flow_recorder/sessions/

# QA 抽检运行产物（截图/XML/CSV/state/pid），体积大且含本机采集痕迹，勿入库
var/

# jadx 反编译输出与报告（保留目录用 recon/output/.gitkeep）
recon/output/**
!recon/output/.gitkeep

# 含本机 mitm CA 片段，由 `run_capture.py --only-config` 生成
capture/scripts/httptoolkit_intercept/config.local.js
